# Python 脚本管理器 - 脚本配置文件
# 在此文件中定义要管理的 Python 脚本

scripts:
  # 示例 1: 手动运行的脚本
  - name: example_script
    script_path: /home/csy/Desktop/xuexi/fastapi_demo/pyscript_mananger/backend/scripts/examply.py
    description: 这是一个示例脚本配置
    schedule_type: manual      # 手动运行
    max_retries: 3             # 最大重试次数
    retry_delay: 60            # 重试间隔(秒)
    timeout: 3600              # 超时时间(秒)
    enabled: true              # 是否启用
    auto_start: false          # 是否自动启动

  # 示例 2: 定时运行的脚本 (Cron 表达式)
  # - name: daily_backup
  #   script_path: /home/user/scripts/backup.py
  #   description: 每日凌晨2点执行备份
  #   schedule_type: cron
  #   schedule: "0 2 * * *"     # Cron 表达式: 分 时 日 月 周
  #   max_retries: 2
  #   retry_delay: 300
  #   timeout: 7200
  #   enabled: true
  #   auto_start: false

  # 示例 3: 间隔运行的脚本
  # - name: health_check
  #   script_path: /home/user/scripts/health_check.py
  #   description: 每5分钟执行健康检查
  #   schedule_type: interval
  #   interval_seconds: 300     # 每300秒执行一次
  #   max_retries: 3
  #   retry_delay: 60
  #   timeout: 300
  #   enabled: true
  #   auto_start: true          # 服务启动时自动开始运行

  # 示例 4: 带环境变量的脚本
  # - name: data_processor
  #   script_path: /home/user/scripts/process.py
  #   description: 数据处理脚本
  #   working_dir: /home/user/data        # 工作目录
  #   env_vars:                           # 环境变量
  #     DEBUG: "false"
  #     LOG_LEVEL: "INFO"
  #     DB_HOST: "localhost"
  #   python_path: /usr/bin/python3       # 指定 Python 解释器
  #   max_retries: 5
  #   retry_delay: 120
  #   timeout: 1800
  #   enabled: true
  #   auto_start: false

# ================== 配置说明 ==================
#
# schedule_type (调度类型):
#   - manual: 手动运行，需要通过界面或 API 触发
#   - cron: 使用 Cron 表达式定时运行
#   - interval: 按固定时间间隔运行
#
# schedule (Cron 表达式格式):
#   "分 时 日 月 周"
#   例如:
#   "*/5 * * * *"  - 每5分钟
#   "0 * * * *"    - 每小时
#   "0 2 * * *"    - 每天凌晨2点
#   "0 0 * * 0"    - 每周日午夜
#   "0 9-17 * * 1-5" - 周一到周五 9点到17点每小时
#
# interval_seconds (间隔秒数):
#   当 schedule_type 为 interval 时生效
#   例如: 60 (每分钟), 300 (每5分钟), 3600 (每小时)
#
# max_retries (最大重试次数):
#   脚本执行失败后自动重试的最大次数
#
# retry_delay (重试间隔):
#   重试之间的等待时间，单位：秒
#
# timeout (超时时间):
#   脚本运行的最大时长，超过后自动终止，单位：秒
#
# enabled (是否启用):
#   false 时脚本不会被调度执行
#
# auto_start (自动启动):
#   true 时服务启动后自动开始运行（仅对 interval 和 cron 类型有效）
#
# working_dir (工作目录):
#   脚本运行的工作目录，默认为脚本所在目录
#
# env_vars (环境变量):
#   脚本运行时的环境变量，键值对形式
#
# python_path (Python 解释器):
#   指定运行脚本的 Python 解释器路径，默认使用系统 Python
# ================================================
